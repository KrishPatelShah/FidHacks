# Base URL of the FastAPI backend (see docker-compose.yml). This is the only
# thing the mobile app needs. The Gemini API key lives ONLY on the backend.
#
# iOS simulator / web:            http://localhost:8000/api  (the default)
# Physical device on the same LAN: http://<your-computer-ip>:8000/api
EXPO_PUBLIC_API_URL=http://localhost:8000/api
