# Public FastAPI base URL used by Expo (see docker-compose.yml).
# The Gemini API key lives ONLY on the backend, never here.
#
# Web / iOS simulator:            http://localhost:8000
# Physical device on the same LAN: http://<your-computer-ip>:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Live stock data for the Stocks tab (https://twelvedata.com — free tier).
# Sign up, copy your API key here. If unset, the Stocks tab falls back to
# simulated mock prices so the demo still works.
EXPO_PUBLIC_TWELVE_DATA_KEY=
